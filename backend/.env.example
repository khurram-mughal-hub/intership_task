# DevelopersHub Backend - Environment Configuration

# Server Port
PORT=5000

# MongoDB Configuration
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/devhub

# OR use MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/devhub?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345

# Admin Credentials (Default)
ADMIN_EMAIL=admin@devhub.com
ADMIN_PASSWORD=admin123

# Environment
NODE_ENV=development

# CORS Settings (optional)
# CORS_ORIGIN=http://localhost:3000

# Notes:
# 1. Change JWT_SECRET to a strong random string in production
# 2. Change ADMIN_PASSWORD to a secure password
# 3. Never commit this file to version control
# 4. For production, use environment variables from hosting platform
